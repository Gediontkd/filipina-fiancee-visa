# Ignore all user PDF folders but keep the structure
/resources/views/pdf/*
!/resources/views/pdf/.gitkeep

# Keep individual user folders tracked but ignore their contents
/resources/views/pdf/user_*/*
!/resources/views/pdf/user_*/.gitkeep

# Ignore temporary merged PDF files
/storage/app/temp/*.pdf
/storage/app/temp/*.json

# Keep temp directory structure
!/storage/app/temp/.gitkeep